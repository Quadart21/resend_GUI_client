[Unit]
Description=Resend GUI Client
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/resend_GUI_client
Environment=PORT=8080
ExecStart=/opt/resend_GUI_client/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
